EDNA_API_KEY=
EDNA_PULSE_SENDER=

APP_BASE_URL=https://your-api.example.com
LOG_LEVEL=info

# Optional: require Authorization: Bearer <secret> on POST /api/webhooks/max/:id
MAX_WEBHOOK_SECRET=
