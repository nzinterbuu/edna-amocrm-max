PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edna_amocrm_max?schema=public

AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://your-api.example.com/api/integrations/amocrm/oauth/callback
AMOCRM_CHANNEL_ID=
AMOCRM_CHANNEL_SECRET=
